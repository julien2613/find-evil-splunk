# Clé du modèle qui pilote l'agent (Claude via LiteLLM)
ANTHROPIC_API_KEY=sk-ant-...

# Optionnel : modèle LiteLLM (défaut anthropic/claude-sonnet-4-6)
# FORENSIC_AGENT_MODEL=anthropic/claude-sonnet-4-6

# Connexion au Splunk MCP Server (sinon lu depuis ../../.mcp_token)
# SPLUNK_MCP_TOKEN=<token Splunk audience=mcp>
# SPLUNK_MCP_URL=https://localhost:8089/services/mcp
